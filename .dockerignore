# 敏感信息 —— 绝不能打入镜像
.env
.env.local
*.pem
*.key

# 版本控制
.git
.gitignore
.gitattributes

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/

# 运行时数据（通过 volume 挂载，不进镜像）
logs/
data/
state/

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo

# 测试覆盖率
.coverage
htmlcov/

# 系统和临时文件
.DS_Store
Thumbs.db
*.tmp
