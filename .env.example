# ==========================================
# Quant Project — 环境变量配置模板
# ==========================================
# 使用方法：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 填入真实值
#   3. 回测模式不需要真实 API Key（可留空）
#   4. Paper / Live 模式必须填入真实 Key
# ==========================================

# Binance API（必填，paper/live 模式）
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# 可选：覆盖 exchange.yaml 中的 testnet 设置
# EXCHANGE_TESTNET=true
